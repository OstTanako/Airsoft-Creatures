; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Airsoft Creatures RE-CODED"
config/description="Airsoft Creatures is back! and more better!!"
config/version="0.0.0dev"
run/main_scene="uid://cag1jsh8avm15"
config/features=PackedStringArray("4.6", "Forward Plus")
run/max_fps=60

[audio]

buses/default_bus_layout="uid://mjdfiwgnsbnr"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=4
window/size/resizable=false
window/stretch/mode="viewport"
window/stretch/aspect="expand"

[editor_plugins]

enabled=PackedStringArray("res://addons/trail_2d/plugin.cfg")

[file_customization]

folder_colors={
"res://Assets/": "red",
"res://Audio Buses/": "teal",
"res://Locations/": "blue",
"res://Scenes/": "orange",
"res://Scripts/": "yellow",
"res://Shaders/": "green"
}

[global_group]

"Limit Line / Player Area"=""
"Board Pinner"="Makes the simple Marker into a board pin."
"Board Animator"="References the BoardAnimatorComponent."
Intruder="Indentifies any harmful entitie"
"Player Bullet"="References the Player`s bullet."

